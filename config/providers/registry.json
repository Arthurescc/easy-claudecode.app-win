{
  "providers": [
    {
      "id": "compatible-coding",
      "displayName": "Compatible coding provider",
      "description": "Use any compatible coding endpoint here, including MiniMax, OpenRouter, Gemini compatibility gateways, Moonshot, or Zhipu-style routes.",
      "legacyIds": [
        "dashscope-codingplan"
      ],
      "settings": [
        {
          "env": "CODING_COMPATIBLE_API_KEY",
          "legacyEnv": "DASHSCOPE_CODINGPLAN_API_KEY",
          "label": "Coding provider API key",
          "type": "password",
          "placeholder": "sk-..."
        },
        {
          "env": "CODING_COMPATIBLE_UPSTREAM",
          "legacyEnv": "CLAUDE_DASHSCOPE_PROXY_UPSTREAM",
          "label": "Coding provider upstream URL",
          "type": "text",
          "placeholder": "https://api.minimaxi.com/v1/chat/completions"
        }
      ],
      "displayAliases": [
        {
          "contains": "minimax",
          "displayName": "MiniMax-compatible"
        },
        {
          "contains": "openrouter",
          "displayName": "OpenRouter-compatible"
        },
        {
          "contains": "gemini",
          "displayName": "Gemini-compatible"
        },
        {
          "contains": "moonshot",
          "displayName": "Moonshot-compatible"
        },
        {
          "contains": "bigmodel",
          "displayName": "Zhipu-compatible"
        },
        {
          "contains": "zhipu",
          "displayName": "Zhipu-compatible"
        }
      ]
    },
    {
      "id": "anthropic-thinking",
