          "label": "Thinking provider API key",
          "type": "password",
          "placeholder": "sk-ant-..."
        },
        {
          "env": "ANTHROPIC_THINKING_UPSTREAM",
          "legacyEnv": "CLAUDE_OPUS_PROXY_UPSTREAM",
          "label": "Thinking provider upstream URL",
          "type": "text",
          "placeholder": "https://api.anthropic.com/v1/messages"
        }
      ]
    }
  ],
