# Core paths
EASY_CLAUDECODE_HOME=$HOME/.easy-claudecode
CLAUDE_WORKSPACE_ROOT=
CLAUDE_EXTRA_ALLOWED_DIRS=

# Console ports
CLAUDE_CONSOLE_HOST=127.0.0.1
CLAUDE_CONSOLE_PORT=18882
CLAUDE_ROUTER_HEALTH_URL=http://127.0.0.1:3456/health
CLAUDE_PROXY_HEALTH_URL=http://127.0.0.1:3460/health

# Claude CLI / Router
CLAUDE_REAL_BIN=
CLAUDE_ROUTER_RUNTIME_DIR=
CLAUDE_ROUTER_CONFIG_FILE=
CLAUDE_ROUTER_CUSTOM_FILE=

# Optional model providers
DASHSCOPE_CODINGPLAN_API_KEY=
AICODELINK_OPUS46_API_KEY=
CLAUDE_DASHSCOPE_PROXY_UPSTREAM=https://coding.dashscope.aliyuncs.com/apps/anthropic/v1/messages
CLAUDE_OPUS_PROXY_UPSTREAM=https://aicodelink.shop/v1/messages

# Optional OpenClaw bridge, disabled by default in the public release
CLAUDE_CONSOLE_ENABLE_OPENCLAW=0
OPENCLAW_HOME=
OPENCLAW_BIN=
OPENCLAW_FIXED_SESSION_APP_PATH=
OPENCLAW_WORKSPACE_ROOTS=
OPENCLAW_SENSITIVE_DOCTRINE_PATH=
OPENCLAW_SENSITIVE_MANIFEST_PATH=
OPENCLAW_SENSITIVE_BROKER_PATH=

